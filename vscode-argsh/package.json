{
  "name": "argsh",
  "displayName": "argsh",
  "description": "Language support, linting, and debugging for argsh — structured Bash scripting framework",
  "version": "0.2.4",
  "publisher": "arg-sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/arg-sh/argsh"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "icon": "icon.png",
  "categories": ["Programming Languages", "Linters", "Debuggers", "Snippets"],
  "activationEvents": ["onLanguage:shellscript", "onDebugResolve:argsh", "onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "argsh.showPreview",
        "title": "Show Script Preview",
        "icon": "$(preview)",
        "category": "argsh"
      },
      {
        "command": "argsh.showHelp",
        "title": "Show Help for Current Function",
        "category": "argsh"
      },
      {
        "command": "argsh.validateScript",
        "title": "Validate Script",
        "category": "argsh"
      },
      {
        "command": "argsh.restartServer",
        "title": "Restart Language Server",
        "category": "argsh"
      },
      {
        "command": "argsh.formatArrays",
        "title": "Format argsh Arrays",
        "category": "argsh"
      },
      {
        "command": "argsh.exportMcpJson",
        "title": "Export MCP JSON",
        "category": "argsh"
      },
      {
        "command": "argsh.exportYaml",
        "title": "Export YAML",
        "category": "argsh"
      },
      {
        "command": "argsh.exportJson",
        "title": "Export JSON",
        "category": "argsh"
      }
    ],
    "keybindings": [
      {
        "command": "argsh.showPreview",
        "key": "ctrl+shift+a",
        "when": "resourceLangId == shellscript"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "argsh.showPreview",
          "when": "resourceLangId == shellscript",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "shellscript",
        "firstLine": "^#!.*\\bargsh\\b"
      }
    ],
    "grammars": [
      {
        "scopeName": "source.shell.argsh",
        "path": "./syntaxes/argsh.tmLanguage.json",
        "injectTo": ["source.shell"]
      }
    ],
    "snippets": [
      {
        "language": "shellscript",
        "path": "./snippets/argsh.json"
      }
    ],

    "viewsContainers": {
      "panel": [
        {
          "id": "argsh-panel",
          "title": "argsh",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "argsh-panel": [
        {
          "id": "argsh.commandTree",
          "name": "Commands",
          "when": "resourceLangId == shellscript"
        }
      ]
    },
    "debuggers": [
      {
        "type": "argsh",
        "label": "argsh Debug",
        "languages": ["shellscript"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the argsh/bash script to debug"
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Arguments to pass to the script",
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the script",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" },
                "description": "Environment variables",
                "default": {}
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop on the first executable line",
                "default": true
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "argsh: Debug Script",
            "description": "Debug an argsh/bash script with breakpoints and stepping",
            "body": {
              "type": "argsh",
              "request": "launch",
              "name": "Debug ${1:script}",
              "program": "${file}",
              "args": [],
              "stopOnEntry": true
            }
          }
        ],
        "initialConfigurations": [
          {
            "type": "argsh",
            "request": "launch",
            "name": "Debug Current File",
            "program": "${file}",
            "stopOnEntry": true
          }
        ]
      }
    ],
    "breakpoints": [
      { "language": "shellscript" }
    ],
    "configuration": {
      "title": "argsh",
      "properties": {
        "argsh.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the argsh language server"
        },
        "argsh.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to argsh-lsp binary (auto-detected if empty)"
        },
        "argsh.commandTree.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the argsh command tree panel"
        },
        "argsh.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show flag/subcommand counts above functions"
        },
        "argsh.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically format argsh arrays on save"
        },
        "argsh.dap.path": {
          "type": "string",
          "default": "",
          "description": "Path to argsh-dap binary (auto-detected if empty)"
        },
        "argsh.resolveDepth": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Maximum depth for resolving imports and source statements across files (0 = current file only)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run build:lsp && npm run build:ext",
    "build:lsp": "cargo build --release --manifest-path ../crates/argsh-lsp/Cargo.toml && mkdir -p bin && cp ../crates/argsh-lsp/target/release/argsh-lsp bin/ && cp ../crates/argsh-lsp/target/release/argsh-dap bin/",
    "build:ext": "npm install && npm run compile",
    "package": "npm run build && vsce package --target linux-x64",
    "package:all": "npm run build && vsce package --target linux-x64 -o argsh-linux-x64.vsix && vsce package --target linux-arm64 -o argsh-linux-arm64.vsix && vsce package --target darwin-x64 -o argsh-darwin-x64.vsix && vsce package --target darwin-arm64 -o argsh-darwin-arm64.vsix",
    "publish": "npm run build && vsce publish",
    "publish:ovsx": "npm run build && npx ovsx publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "@types/node": "^22.0.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
